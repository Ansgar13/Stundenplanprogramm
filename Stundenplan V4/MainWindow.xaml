<Window x:Class="Stundenplan_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stundenplan V2"
        Height="975"
        Width="675"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Stundenplan-Generator" FontSize="20"
                   FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <Button Grid.Row="1"  Content="1. Zeitwünsche einlesen" Margin="0,0,0,10" Click="BtnZeitwuensche_Click"/>
        <Button Grid.Row="2"  Content="2. Excel-Datei einlesen" Margin="0,0,0,10" Click="BtnPfad_Click"/>
        <Button Grid.Row="3"  Content="3. Stundenplanerstellung" Margin="0,0,0,10" Click="BtnSchritt2_Click"/>
        <Button Grid.Row="4"  Content="4. Lehrerpläne erzeugen" Margin="0,0,0,10" Click="BtnLehrerplaene_Click"/>
        <Button Grid.Row="5"  Content="5. Klassenpläne erzeugen" Margin="0,0,0,10" Click="BtnKlassenplaene_Click"/>
        <Button Grid.Row="6"  Content="5b. Klassenpläne EF / Q1 / Q2" Margin="0,0,0,10" Click="BtnKlassenplaeneOberstufe_Click"/>
        <Button Grid.Row="7"  Content="6. UNr-Plan bewerten" Margin="0,0,0,10" Click="BtnUnrPlan_Click"/>
        <Button Grid.Row="8"  Content="7. Klasse fixieren → Fix UNrn" Margin="0,0,0,10" Click="BtnKlasseFixieren_Click"/>
        <Button Grid.Row="9"  Content="8. UNr-Plan prüfen (Verletzungen)" Margin="0,0,0,10" Click="BtnPlanPrüfen_Click"/>
        <Button Grid.Row="10" Content="9. Plan verbessern" Margin="0,0,0,10" Click="BtnPlanVerbessern_Click"/>
        <Button Grid.Row="11" Content="10. Fix UNrn löschen" Margin="0,0,0,10" Click="BtnFixUNrnLoeschen_Click"/>
        <Button Grid.Row="12" Content="Gezielt ignorieren" Margin="0,0,0,10" Click="BtnIgnorieren_Click"/>
        <Button Grid.Row="13" Content="Gezielt fixieren"   Margin="0,0,0,10" Click="BtnFixieren_Click"/>
        <Button Grid.Row="14" Content="Plan-Editor (interaktiv)" Margin="0,0,0,10" Click="BtnPlanEditor_Click"/>
        <Button Grid.Row="15" Content="Lösung sichern" Margin="0,0,0,10" Click="BtnLoesungSichern_Click"/>
        <Button Grid.Row="16" Content="Gesicherte Lösung löschen" Margin="0,0,0,10" Click="BtnGesicherteLoesungLoeschen_Click"/>
        <Button Grid.Row="17" Content="11. Minimale Änderungen (Solver)" Margin="0,0,0,10" Click="BtnMinimalAenderung_Click"/>

        <TextBox x:Name="TxtLog" Grid.Row="18" Margin="0,10,0,10"
                 VerticalScrollBarVisibility="Auto" AcceptsReturn="True"
                 IsReadOnly="True" FontFamily="Consolas"/>

        <Border Grid.Row="19" Background="#F0F0F0" Padding="10" CornerRadius="5">
            <TextBlock x:Name="TxtStatus" Text="Bereit." FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>