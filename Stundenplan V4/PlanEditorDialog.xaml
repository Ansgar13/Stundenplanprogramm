<Window x:Class="Stundenplan_V2.PlanEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Plan-Editor" Width="1800" Height="1144"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="200" x:Name="RowPlaene"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.2*" MinHeight="80" x:Name="RowDetail"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Kopfzeile: Loesung + Modus -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Loesung:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <Button x:Name="BtnVorigeLoesung" Content="&#9664;" Width="28" VerticalAlignment="Center"
                    Margin="0,0,2,0" ToolTip="Vorige Loesung" Click="BtnVorigeLoesung_Click"/>
            <ComboBox x:Name="CboLoesung" Width="160" VerticalAlignment="Center" Margin="0,0,2,0"
                      SelectionChanged="CboLoesung_SelectionChanged"/>
            <Button x:Name="BtnNaechsteLoesung" Content="&#9654;" Width="28" VerticalAlignment="Center"
                    Margin="0,0,30,0" ToolTip="Naechste Loesung" Click="BtnNaechsteLoesung_Click"/>

            <TextBlock Text="Modus:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <RadioButton x:Name="RbBlock"  Content="Block (ganzer Tag)" GroupName="Modus"
                         VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton x:Name="RbEinzel" Content="Einzelstunde" GroupName="Modus" IsChecked="True"
                         VerticalAlignment="Center" Margin="0,0,30,0"/>

            <CheckBox x:Name="ChkSpaetePaed" Content="Spaete nichtfixierte paed. Einheiten rot"
                      VerticalAlignment="Center" Margin="0,0,20,0" Checked="ChkSpaetePaed_Changed" Unchecked="ChkSpaetePaed_Changed"/>

            <CheckBox x:Name="ChkKlassenVergleich" Content="Klassenvergleich zeigen"
                      VerticalAlignment="Center" Margin="0,0,20,0" Checked="ChkKlassenVergleich_Changed" Unchecked="ChkKlassenVergleich_Changed"/>

            <CheckBox x:Name="ChkVergleichsModus" Content="Vergleichsmodus (2 Lösungen)"
                      VerticalAlignment="Center" Margin="0,0,10,0" Checked="ChkVergleichsModus_Changed" Unchecked="ChkVergleichsModus_Changed"/>
            <TextBlock x:Name="LblVglLoesung" Text="2. Lösung:" FontWeight="Bold" VerticalAlignment="Center"
                       Margin="0,0,6,0" Visibility="Collapsed"/>
            <Button x:Name="BtnVorigeVglLoesung2" Content="&#9664;" Width="28" VerticalAlignment="Center"
                    Margin="0,0,2,0" ToolTip="Vorige 2. Lösung" Click="BtnVorigeVglLoesung2_Click" Visibility="Collapsed"/>
            <ComboBox x:Name="CboVglLoesung2" Width="160" VerticalAlignment="Center" Margin="0,0,2,0"
                      SelectionChanged="CboVglLoesung2_SelectionChanged" Visibility="Collapsed"/>
            <Button x:Name="BtnNaechsteVglLoesung2" Content="&#9654;" Width="28" VerticalAlignment="Center"
                    ToolTip="Nächste 2. Lösung" Click="BtnNaechsteVglLoesung2_Click" Visibility="Collapsed"/>
        </StackPanel>

        <!-- Hinweiszeile -->
        <TextBlock Grid.Row="1" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#555"
                   Text="Links Lehrerplan, rechts Klassenplan. Klick auf eine Zelle zeigt im anderen Plan die zugehoerige Klasse bzw. den Lehrer. Ziehen: leere Zelle = verschieben, belegte Zelle gleicher Stundenzahl = tauschen, Parkbereich = entplanen. Ressourcenkonflikte werden hart gesperrt; Qualitaetsprobleme gelb gewarnt."/>

        <!-- Hauptbereich: Lehrerplan | Klassenplan | Vergleich-Vorher | Vergleich-Nachher | KlVgl-Vorher | KlVgl-Nachher -->
        <ScrollViewer x:Name="ScrollEditAnsicht" Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEHRER-PLAN -->
            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Height="32">
                        <TextBlock Text="Lehrer:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnVorigerLehrer" Content="&#9664;" Width="28" VerticalAlignment="Center"
                                Margin="0,0,2,0" ToolTip="Voriger Lehrer" Click="BtnVorigerLehrer_Click"/>
                        <ComboBox x:Name="CboLehrer" Width="140" VerticalAlignment="Center" Margin="0,0,2,0"
                                  SelectionChanged="CboLehrer_SelectionChanged"/>
                        <Button x:Name="BtnNaechsterLehrer" Content="&#9654;" Width="28" VerticalAlignment="Center"
                                ToolTip="Naechster Lehrer" Click="BtnNaechsterLehrer_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LEHRERPLAN" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid x:Name="LehrerGrid"/>
                            <Canvas x:Name="LehrerCanvas" IsHitTestVisible="False"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- KLASSEN-PLAN -->
            <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1" Margin="4,0,4,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Height="32">
                        <TextBlock Text="Klasse:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnVorigeKlasse" Content="&#9664;" Width="28" VerticalAlignment="Center"
                                Margin="0,0,2,0" ToolTip="Vorige Klasse" Click="BtnVorigeKlasse_Click"/>
                        <ComboBox x:Name="CboKlasse" Width="140" VerticalAlignment="Center" Margin="0,0,2,0"
                                  SelectionChanged="CboKlasse_SelectionChanged"/>
                        <Button x:Name="BtnNaechsteKlasse" Content="&#9654;" Width="28" VerticalAlignment="Center"
                                ToolTip="Naechste Klasse" Click="BtnNaechsteKlasse_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="KLASSENPLAN" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid x:Name="KlasseGrid"/>
                            <Canvas x:Name="KlasseCanvas" IsHitTestVisible="False"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- VERGLEICH VORHER -->
            <Border Grid.Column="2" x:Name="BrdVglVorher" BorderBrush="#CCC" BorderThickness="1"
                    Margin="4,0,4,0" Background="#FBFBFB" Visibility="Collapsed">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Height="32">
                        <TextBlock Text="Vgl.-Lehrer:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnVorigerVglLehrer" Content="&#9664;" Width="28" VerticalAlignment="Center"
                                Margin="0,0,2,0" Click="BtnVorigerVglLehrer_Click"/>
                        <ComboBox x:Name="CboVglLehrer" Width="120" VerticalAlignment="Center" Margin="0,0,2,0"
                                  SelectionChanged="CboVglLehrer_SelectionChanged"/>
                        <Button x:Name="BtnNaechsterVglLehrer" Content="&#9654;" Width="28" VerticalAlignment="Center"
                                Click="BtnNaechsterVglLehrer_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="VORHER" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid x:Name="GridVglVorher"/>
                            <Canvas x:Name="VglVorherCanvas" IsHitTestVisible="False"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- VERGLEICH NACHHER -->
            <Border Grid.Column="3" x:Name="BrdVglNachher" BorderBrush="#CCC" BorderThickness="1"
                    Margin="4,0,4,0" Background="#FBFBFB" Visibility="Collapsed">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="32" Margin="4"/>
                    <TextBlock DockPanel.Dock="Top" Text="NACHHER" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="GridVglNachher"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- KLASSEN-VERGLEICH VORHER -->
            <Border Grid.Column="4" x:Name="BrdVglKlasseVorher" BorderBrush="#CCC" BorderThickness="1"
                    Margin="4,0,4,0" Background="#FBFBFB" Visibility="Collapsed">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="4" Height="32">
                        <TextBlock Text="Vgl.-Klasse:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button x:Name="BtnVorigeVglKlasse" Content="&#9664;" Width="28" VerticalAlignment="Center"
                                Margin="0,0,2,0" Click="BtnVorigeVglKlasse_Click"/>
                        <ComboBox x:Name="CboVglKlasse" Width="120" VerticalAlignment="Center" Margin="0,0,2,0"
                                  SelectionChanged="CboVglKlasse_SelectionChanged"/>
                        <Button x:Name="BtnNaechsteVglKlasse" Content="&#9654;" Width="28" VerticalAlignment="Center"
                                Click="BtnNaechsteVglKlasse_Click"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="VORHER (Klasse)" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid x:Name="GridVglKlasseVorher"/>
                            <Canvas x:Name="VglKlasseVorherCanvas" IsHitTestVisible="False"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- KLASSEN-VERGLEICH NACHHER -->
            <Border Grid.Column="5" x:Name="BrdVglKlasseNachher" BorderBrush="#CCC" BorderThickness="1"
                    Margin="4,0,0,0" Background="#FBFBFB" Visibility="Collapsed">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Height="32" Margin="4"/>
                    <TextBlock DockPanel.Dock="Top" Text="NACHHER (Klasse)" FontWeight="Bold" Height="20"
                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="GridVglKlasseNachher"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
        </ScrollViewer>

        <!-- VERGLEICHSMODUS: 1x4 (Lehrer A | Lehrer B | Klasse A | Klasse B nebeneinander) -->
        <ScrollViewer x:Name="ScrollVergleichsModus" Grid.Row="2" Visibility="Collapsed"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Left">
        <DockPanel>
            <!-- Eigene Lehrer/Klasse-Navigationsleiste (die Dropdowns der Editieransicht
                 sind im Vergleichsmodus ausgeblendet und daher nicht erreichbar) -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4" Height="32">
                <TextBlock Text="Lehrer:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="BtnVmVorigerLehrer" Content="&#9664;" Width="28" VerticalAlignment="Center"
                        Margin="0,0,2,0" ToolTip="Voriger Lehrer" Click="BtnVorigerLehrer_Click"/>
                <ComboBox x:Name="CboVmLehrer" Width="140" VerticalAlignment="Center" Margin="0,0,2,0"
                          SelectionChanged="CboVmLehrer_SelectionChanged"/>
                <Button x:Name="BtnVmNaechsterLehrer" Content="&#9654;" Width="28" VerticalAlignment="Center"
                        Margin="0,0,24,0" ToolTip="Naechster Lehrer" Click="BtnNaechsterLehrer_Click"/>

                <TextBlock Text="Klasse:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Button x:Name="BtnVmVorigeKlasse" Content="&#9664;" Width="28" VerticalAlignment="Center"
                        Margin="0,0,2,0" ToolTip="Vorige Klasse" Click="BtnVorigeKlasse_Click"/>
                <ComboBox x:Name="CboVmKlasse" Width="140" VerticalAlignment="Center" Margin="0,0,2,0"
                          SelectionChanged="CboVmKlasse_SelectionChanged"/>
                <Button x:Name="BtnVmNaechsteKlasse" Content="&#9654;" Width="28" VerticalAlignment="Center"
                        ToolTip="Naechste Klasse" Click="BtnNaechsteKlasse_Click"/>
            </StackPanel>

        <Grid x:Name="GridVergleichsModus">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Lehrer Lösung A -->
            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,2,0">
                <DockPanel>
                    <TextBlock x:Name="LblVmLehrerA" DockPanel.Dock="Top" Text="LEHRER – Lösung A"
                               FontWeight="Bold" Height="20" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="VmLehrerGridA"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Lehrer Lösung B -->
            <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1" Margin="2,0,2,0" Background="#FBFBFB">
                <DockPanel>
                    <TextBlock x:Name="LblVmLehrerB" DockPanel.Dock="Top" Text="LEHRER – Lösung B"
                               FontWeight="Bold" Height="20" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="VmLehrerGridB"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Klasse Lösung A -->
            <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" Margin="8,0,2,0">
                <DockPanel>
                    <TextBlock x:Name="LblVmKlasseA" DockPanel.Dock="Top" Text="KLASSE – Lösung A"
                               FontWeight="Bold" Height="20" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="VmKlasseGridA"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Klasse Lösung B -->
            <Border Grid.Column="3" BorderBrush="#CCC" BorderThickness="1" Margin="2,0,0,0" Background="#FBFBFB">
                <DockPanel>
                    <TextBlock x:Name="LblVmKlasseB" DockPanel.Dock="Top" Text="KLASSE – Lösung B"
                               FontWeight="Bold" Height="20" HorizontalAlignment="Center" Margin="0,2,0,2"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid x:Name="VmKlasseGridB"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
        </DockPanel>
        </ScrollViewer>

        <!-- Parkbereich (waagerecht unter den Plaenen) -->
        <Border x:Name="BrdParkbereich" Grid.Row="3" BorderBrush="#CCC" BorderThickness="1" Margin="0,8,0,0"
                Background="#FAFAFA" AllowDrop="True" Drop="Parkbereich_Drop" DragOver="Zelle_DragOver"
                Height="90">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Parkbereich (nicht verplant) - hierher ziehen zum Entplanen"
                           FontWeight="Bold" Margin="6,4,6,2"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ParkPanel" Orientation="Horizontal" Margin="4"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Verschiebbarer Trenner: Stundenplan/Parkbereich <-> Diagnose.
             Resized Row 2 (Pläne) gegen Row 5 (Detailbereich): nach unten ziehen
             vergrößert die Pläne, nach oben den Detailbereich. -->
        <GridSplitter x:Name="SplitterDetail" Grid.Row="4" Height="6" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" Background="#999"
                      ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Margin="0,4,0,0" Cursor="SizeNS"/>

        <!-- Detail-Bereich: links Tauschliste, daneben Verschiebung, daneben Details/Diagnose.
             Spalten sind über GridSplitter verschiebbar; Min-Breiten verhindern Verschwinden. -->
        <Border x:Name="BrdDetailBereich" Grid.Row="5" BorderBrush="#DDD" BorderThickness="1" Margin="0,8,0,0" Padding="6"
                Background="#F7F7F7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" MinWidth="60"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220" MinWidth="60"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="120"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#EEE" BorderThickness="0,0,1,0" Padding="0,0,6,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Tauschvorschlaege:" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="PnlTausch"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#CCC"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Cursor="SizeWE"/>

                <Border Grid.Column="2" BorderBrush="#EEE" BorderThickness="0,0,1,0" Padding="6,0,6,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Verschiebung mit Ausweich:" FontWeight="Bold" Margin="0,0,0,4"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="PnlVerschieb"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch" Background="#CCC"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Cursor="SizeWE"/>

                <DockPanel Grid.Column="4" Margin="6,0,0,0">
                    <TextBlock DockPanel.Dock="Top" Text="Details / Diagnose:" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TxtDetails" TextWrapping="Wrap" Text="(noch keine Auswahl)" FontFamily="Consolas" FontSize="16.5"/>
                    </ScrollViewer>
                </DockPanel>
            </Grid>
        </Border>

        <!-- Statuszeile + Buttons (linksbuendig) -->
        <Grid Grid.Row="6" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnReset"       Content="Zuruecksetzen" Width="120" Margin="0,0,6,0" Click="BtnReset_Click"/>
                <Button x:Name="BtnUebernehmen" Content="Uebernehmen"   Width="180" Margin="0,0,6,0" Click="BtnUebernehmen_Click"/>
                <Button x:Name="BtnSchliessen"  Content="Schliessen"    Width="100" Margin="0,0,20,0" Click="BtnSchliessen_Click"/>
                <TextBlock x:Name="TxtStatus" VerticalAlignment="Center" Text="Bereit." FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
